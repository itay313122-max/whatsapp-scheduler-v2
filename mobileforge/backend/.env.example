PORT=4000
FRONTEND_URL=http://localhost:3000

# ── LLM providers (tried in this fallback order) ───────────────────────────
# At least one is needed for real AI generation; with none set the app runs in
# deterministic demo mode. Each provider is skipped if its key is absent.
# Groq (free — https://console.groq.com/keys)
GROQ_API_KEY=gsk_...
# Google Gemini (free — https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...
# OpenRouter (free :free models — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
# Cerebras (free, very fast — https://cloud.cerebras.ai)
CEREBRAS_API_KEY=csk-...
# Together AI (free credit — https://api.together.xyz/settings/api-keys)
TOGETHER_API_KEY=...

# Admin: protects GET /api/feedback and /api/backup endpoints. Any secret string.
# If not set, a random token is auto-generated and printed to the console.
ADMIN_TOKEN=

# Closed beta: comma-separated invite codes (the ones you send to friends).
# Leave empty to disable the gate (anyone can enter). Example:
# BETA_KEYS=MF-AAAA-1111,MF-BBBB-2222
BETA_KEYS=

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Data storage directory (defaults to .data/ in project root)
# DATA_DIR=.data

# Rate limiting (per AI-generation endpoints)
# RATE_LIMIT_PER_MIN=10
# RATE_LIMIT_PER_DAY=150
# GLOBAL_DAILY_CAP=5000
