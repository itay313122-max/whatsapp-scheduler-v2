PORT=4000
FRONTEND_URL=http://localhost:3000

# ── LLM providers (tried in this fallback order) ───────────────────────────
# At least one is needed for real AI generation; with none set the app runs in
# deterministic demo mode. Each provider is skipped if its key is absent.
# Groq (free — https://console.groq.com/keys)
GROQ_API_KEY=gsk_...
# Google Gemini (free — https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...
# OpenRouter (free :free models — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
# Cerebras (free, very fast — https://cloud.cerebras.ai)
CEREBRAS_API_KEY=csk-...
# Together AI (free credit — https://api.together.xyz/settings/api-keys)
TOGETHER_API_KEY=...

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
