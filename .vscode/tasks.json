{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MobileForge: Install (backend + frontend)",
      "type": "shell",
      "command": "cd mobileforge/backend && npm install && cd ../frontend && npm install",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "MobileForge: Run backend (dev)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/mobileforge/backend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "mobileforge" }
    },
    {
      "label": "MobileForge: Run frontend (dev)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/mobileforge/frontend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "mobileforge" }
    },
    {
      "label": "MobileForge: Run FULL app (backend + frontend)",
      "dependsOn": [
        "MobileForge: Run backend (dev)",
        "MobileForge: Run frontend (dev)"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "MobileForge: Test backend (231 tests)",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/mobileforge/backend" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "MobileForge: Typecheck backend",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "options": { "cwd": "${workspaceFolder}/mobileforge/backend" },
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "MobileForge: Typecheck frontend",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "options": { "cwd": "${workspaceFolder}/mobileforge/frontend" },
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "MobileForge: Build backend",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/mobileforge/backend" },
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "MobileForge: Build frontend",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/mobileforge/frontend" },
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "MobileForge: Check AI provider status",
      "type": "shell",
      "command": "curl -s http://localhost:4000/api/generate/ai-status | node -e \"let d='';process.stdin.on('data',c=>d+=c).on('end',()=>console.log(JSON.stringify(JSON.parse(d),null,2)))\"",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
